{
  "manifest_version": 3,
  "name": "Kueski Widget Pro",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting", "tabs", "notifications", "alarms", "storage"],
  "host_permissions": [
    "*://*.amazon.com.mx/*",
    "*://*.amazon.com/*",
    "*://*.bodegaaurrera.com.mx/*",
    "*://bodegaaurrera.com.mx/*",
    "http://127.0.0.1:3001/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com.mx/*", "*://*.amazon.com/*", "*://*.bodegaaurrera.com.mx/*", "*://bodegaaurrera.com.mx/*"],
      "js": ["assets/content.js"], 
      "run_at": "document_idle"
    }
  ]
}
