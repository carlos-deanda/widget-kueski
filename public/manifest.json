{
  "manifest_version": 3,
  "name": "Kueski Widget Pro",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["*://*.amazon.com.mx/*", "*://*.amazon.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com.mx/*", "*://*.amazon.com/*"],
      "js": ["assets/content.js"], 
      "run_at": "document_idle"
    }
  ]
}
